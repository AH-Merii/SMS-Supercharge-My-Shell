{
  "profiles": [
    {
      "complex_modifications": {
        "rules": [
          {
            "description": "Hyper+S/F in Ghostty → shell commands (bypass fzf conflict)",
            "manipulators": [
              {
                "conditions": [
                  {
                    "bundle_identifiers": ["^com\\.mitchellh\\.ghostty$"],
                    "type": "frontmost_application_if"
                  }
                ],
                "from": {
                  "key_code": "s",
                  "modifiers": {
                    "mandatory": ["command", "control", "option", "shift"]
                  }
                },
                "to": [{ "shell_command": "open -a Slack" }],
                "type": "basic"
              },
              {
                "conditions": [
                  {
                    "bundle_identifiers": ["^com\\.mitchellh\\.ghostty$"],
                    "type": "frontmost_application_if"
                  }
                ],
                "from": {
                  "key_code": "f",
                  "modifiers": {
                    "mandatory": ["command", "control", "option", "shift"]
                  }
                },
                "to": [{ "shell_command": "open -g 'raycast://extensions/raycast/window-management/toggle-fullscreen'" }],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Track Tab Switcher State",
            "manipulators": [
              {
                "from": {
                  "key_code": "tab",
                  "modifiers": {
                    "mandatory": ["control"],
                    "optional": ["shift"]
                  }
                },
                "to": [
                  {
                    "key_code": "tab",
                    "modifiers": ["left_control"]
                  },
                  {
                    "set_variable": {
                      "name": "ctrl_tab_active",
                      "value": 1
                    }
                  }
                ],
                "type": "basic"
              },
              {
                "from": {
                  "key_code": "tab",
                  "modifiers": {
                    "mandatory": ["option"],
                    "optional": ["shift"]
                  }
                },
                "to": [
                  {
                    "key_code": "tab",
                    "modifiers": ["left_option"]
                  },
                  {
                    "set_variable": {
                      "name": "alt_tab_active",
                      "value": 1
                    }
                  }
                ],
                "type": "basic"
              },
              {
                "from": { "key_code": "left_control" },
                "to": [{ "key_code": "left_control" }],
                "to_after_key_up": [
                  {
                    "set_variable": {
                      "name": "ctrl_tab_active",
                      "value": 0
                    }
                  }
                ],
                "type": "basic"
              },
              {
                "from": { "key_code": "right_control" },
                "to": [{ "key_code": "right_control" }],
                "to_after_key_up": [
                  {
                    "set_variable": {
                      "name": "ctrl_tab_active",
                      "value": 0
                    }
                  }
                ],
                "type": "basic"
              },
              {
                "from": { "key_code": "left_option" },
                "to": [{ "key_code": "left_option" }],
                "to_after_key_up": [
                  {
                    "set_variable": {
                      "name": "alt_tab_active",
                      "value": 0
                    }
                  }
                ],
                "type": "basic"
              },
              {
                "from": { "key_code": "right_option" },
                "to": [{ "key_code": "right_option" }],
                "to_after_key_up": [
                  {
                    "set_variable": {
                      "name": "alt_tab_active",
                      "value": 0
                    }
                  }
                ],
                "type": "basic"
              }
            ]
