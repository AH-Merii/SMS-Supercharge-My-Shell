{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(bun --version)",
      "Bash(bun pm ls *)",
      "Bash(gh api *)",
      "Bash(gh auth status *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh search *)",
      "Bash(git branch)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npm ls *)",
      "Bash(pnpm --version)",
      "Bash(pnpm list *)",
      "Bash(rm -rf /tmp/*)",
      "Bash(tmux *)",
      "Bash(tree *)",
      "Bash(uv --version)",
      "Bash(uv pip list)",
      "Bash(uv tree *)",
      "Bash(wc *)",
      "Bash(yarn --version)",
      "Edit(~/SMS-Supercharge-My-Shell/**)",
      "Glob(**)",
      "Grep(**)",
      "Read(**)",
      "WebFetch(domain:antidote.sh)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:astral.sh)",
      "WebFetch(domain:bun.pm)",
      "WebFetch(domain:bun.sh)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:eu-central-1-1.aws.cloud2.influxdata.com)",
      "WebFetch(domain:fishshell.com)",
      "WebFetch(domain:formulae.brew.sh)",
      "WebFetch(domain:ghostty.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:man.archlinux.org)",
      "WebFetch(domain:manpages.debian.org)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:pnpm.io)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:samedwardes.com)",
      "WebSearch",
      "Write(~/SMS-Supercharge-My-Shell/**)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(**/secrets/**)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/.netrc)",
      "Read(**/.docker/config.json)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(~/.config/gcloud/**)",
      "Read(id_rsa)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Write(~/.ssh/**)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(dd *)",
      "Bash(ssh *)",
      "Bash(eval *)",
      "Bash(chmod 777 *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(git commit --no-gpg-sign *)",
      "Bash(op read *)",
      "Bash(op item *)",
      "Bash(op vault *)",
      "Bash(op document *)",
      "Bash(op inject *)",
      "Bash(op run *)",
      "Bash(op account *)",
      "Bash(op connect *)",
      "Bash(op plugin *)",
      "Bash(op service-account *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ],
    "ask": [
      "Bash(rm -rf ./*)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git rm *)",
      "Bash(git restore *)",
      "Bash(npm install *)",
      "Bash(npm ci *)",
      "Bash(bun install *)",
      "Bash(bun add *)",
      "Bash(bun remove *)",
      "Bash(uv sync *)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "Bash(uv pip install *)",
      "Bash(uv pip uninstall *)",
      "Bash(uv venv *)",
      "WebFetch(domain:*)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr review *)",
      "Bash(gh issue create *)",
      "Bash(gh issue close *)",
      "Bash(gh issue edit *)",
      "Bash(gh issue comment *)",
      "Bash(gh issue delete *)",
      "Bash(gh repo create *)",
      "Bash(gh repo delete *)",
      "Bash(gh repo edit *)",
      "Bash(gh repo fork *)",
      "Bash(gh repo clone *)",
      "Bash(gh release create *)",
      "Bash(gh release delete *)",
      "Bash(gh release edit *)",
      "Bash(gh run rerun *)",
      "Bash(gh run cancel *)",
      "Bash(stow --adopt *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/enforce-uv.sh"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/enforce-rg.sh"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/enforce-fd.sh"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/enforce-stow.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/prettier-format.sh"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/check-actions-versions.sh"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/track-git-edits.sh"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/marimo-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/notify-stop.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/sync-webfetch-rules.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/remind-git-docs.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/notify-notification.sh",
            "async": true
          }
        ]
      }
    ],
    "Setup": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/validate-env.sh"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/sync-agent-skills.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/skill-eval.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "terminal-icons@local-plugins": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "uploads.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org"
      ],
      "allowUnixSockets": [
        "/Users/ah_merii/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
      ],
      "allowLocalBinding": true
    }
  },
  "pluginMarketplaces": ["~/.config/claude/plugins/marketplace.json"]
}
