#!/bin/sh
# git-reword — change a commit message (latest or by hash)
# Placed on PATH as git-reword so `git reword` just works.

set -e

msg=""
hash=""

while [ $# -gt 0 ]; do
    case "$1" in
        -m) msg="$2"; shift 2 ;;
        *)  hash="$1"; shift ;;
    esac
done

if [ -z "$hash" ]; then
    # Reword the previous commit
    if [ -n "$msg" ]; then
        exec git commit --amend -m "$msg"
    else
        exec git commit --amend
    fi
else
    # Reword a specific commit via interactive rebase
    short=$(git rev-parse --short "$hash")

    # Root commit has no parent — use --root
    if git rev-parse --verify "$hash^" >/dev/null 2>&1; then
        rebase_arg="$hash^"
    else
        rebase_arg="--root"
    fi

    if [ -n "$msg" ]; then
        tmp=$(mktemp)
        trap 'rm -f "$tmp"' EXIT
        printf '%s\n' "$msg" > "$tmp"

        GIT_EDITOR="cp $tmp" \
        GIT_SEQUENCE_EDITOR="sed -i '' 's/^pick $short/reword $short/'" \
        git rebase -i $rebase_arg
    else
        GIT_SEQUENCE_EDITOR="sed -i '' 's/^pick $short/reword $short/'" \
        exec git rebase -i $rebase_arg
    fi
fi
